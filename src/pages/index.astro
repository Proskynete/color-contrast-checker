---
import LandingLayout from '../layouts/landing.layout.astro';
import { AiPalette } from './sections/_ai-palette.tsx';
import { AiSuggest } from './sections/_ai-suggest.tsx';
import { BulkChecker } from './sections/_bulk-checker.tsx';
import { CheckHistory } from './sections/_check-history.tsx';
import { ContrastResult } from './sections/_contrast-result.tsx';
import { Form } from './sections/_form.tsx';
import { PaletteManager } from './sections/_palette-manager.tsx';
import { Preview } from './sections/_preview.tsx';
import { TeamManager } from './sections/_team-manager.tsx';
import { ToolsPanel } from './sections/_tools-panel.tsx';
import { sql } from '../db/client';

const { userId: clerkId } = Astro.locals.auth();

let isSignedIn = false;
let plan = 'free';
let creditsUsed = 0;
let teamId: string | null = null;
let teamRole: string | null = null;
let teamStatus: string | null = null;

if (clerkId) {
	isSignedIn = true;
	const rows = await sql.query(
		`SELECT plan, ai_credits_used FROM users WHERE clerk_id = $1`,
		[clerkId],
	) as { plan: string; ai_credits_used: number }[];

	if (rows.length) {
		plan = rows[0].plan;
		creditsUsed = rows[0].ai_credits_used;
	}

	if (plan === 'teams') {
		const teamRows = await sql.query(
			`SELECT t.id, t.status, tm.role
			 FROM teams t
			 JOIN team_members tm ON t.id = tm.team_id
			 JOIN users u ON u.id = tm.user_id
			 WHERE u.clerk_id = $1 AND t.status != 'deleted'
			 LIMIT 1`,
			[clerkId],
		) as { id: string; status: string; role: string }[];

		if (teamRows.length) {
			teamId = teamRows[0].id;
			teamStatus = teamRows[0].status;
			teamRole = teamRows[0].role;
		}
	}
}
---

<LandingLayout>
	<!-- Hero -->
	<div class="text-center pt-2 pb-1">
		<h1 class="text-4xl font-bold text-[#111827] tracking-tight">Contrast Checker</h1>
		<p class="text-[#6B7280] mt-2 max-w-lg mx-auto text-sm leading-relaxed">
			Check your colors' contrast against WCAG guidelines and get AI suggestions to improve accessibility.
		</p>
	</div>

	<!-- Asymmetric 2-column layout: controls (1fr) | workspace (2fr) -->
	<div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-5">
		<!-- Left column: compact controls -->
		<div class="flex flex-col gap-5">
			<Form client:visible />
			<ContrastResult client:visible isSignedIn={isSignedIn} />
			<AiSuggest
				client:load
				isSignedIn={isSignedIn}
				plan={plan}
				creditsUsed={creditsUsed}
			/>
		</div>

		<!-- Right column: spacious workspace -->
		<div class="flex flex-col gap-5">
			<Preview client:visible />
			<ToolsPanel client:load />
		</div>
	</div>

	<!-- History + Palette + Bulk + AI Palette + Team row -->
	<div class="flex items-center gap-3 justify-end flex-wrap">
		<CheckHistory client:load isSignedIn={isSignedIn} plan={plan} />
		<BulkChecker client:load isSignedIn={isSignedIn} plan={plan} />
		<AiPalette
			client:load
			isSignedIn={isSignedIn}
			plan={plan}
			teamId={teamId}
			teamRole={teamRole}
			teamStatus={teamStatus}
		/>
		<PaletteManager
			client:load
			isSignedIn={isSignedIn}
			plan={plan}
			teamId={teamId}
			teamRole={teamRole}
			teamStatus={teamStatus}
		/>
		<TeamManager client:load isSignedIn={isSignedIn} plan={plan} />
	</div>
</LandingLayout>
