---
import { Show, SignInButton, UserButton } from '@clerk/astro/components';
---

<header class="w-full border-b border-[#E5E7EB] bg-white">
	<div class="max-w-7xl w-full mx-auto px-5 md:px-8 h-14 flex items-center justify-between">
		<div class="flex items-center gap-2.5">
			<img src="/images/favicon.svg" alt="C3 Logo" class="w-7 h-7 shrink-0" />
			<span class="text-sm font-semibold text-[#111827] hidden sm:block">Color Contrast Checker</span>
		</div>

		<div class="flex items-center gap-2">
			<Show when="signed-out">
				<a href="/pricing" class="h-8 px-3 text-xs font-semibold rounded-lg text-[#6B7280] hover:text-[#111827] transition-colors flex items-center">
					Pricing
				</a>
				<SignInButton
					mode="modal"
					data-clerk-sign-in
					class="h-8 px-4 text-xs font-semibold rounded-lg border border-[#E5E7EB] bg-white text-[#374151] hover:bg-[#F9FAFB] hover:border-[#D1D5DB] transition-colors"
				>
					Sign in
				</SignInButton>
			</Show>
			<Show when="signed-in">
				<a href="/pricing" class="h-8 px-3 text-xs font-semibold rounded-lg text-[#6B7280] hover:text-[#111827] transition-colors flex items-center">
					Billing
				</a>
				<UserButton />
			</Show>
		</div>
	</div>
</header>
