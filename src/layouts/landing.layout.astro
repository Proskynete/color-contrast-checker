---
import Header from './components/header.astro';
import Footer from './components/footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const SITE_URL = 'https://c3.eduardoalvarez.dev';
const DEFAULT_TITLE = 'C3 — Free WCAG Color Contrast Checker with AI Suggestions';
const DEFAULT_DESCRIPTION = 'Free WCAG color contrast checker with AI color correction, palette harmonies, daltonism simulation, image color picker, and shareable links. Verify AA/AAA compliance instantly.';
const DEFAULT_OG_IMAGE = `${SITE_URL}/og.png`;

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonical = SITE_URL,
  ogImage = DEFAULT_OG_IMAGE,
  noindex = false,
} = Astro.props;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'C3 — Color Contrast Checker',
  url: SITE_URL,
  description: DEFAULT_DESCRIPTION,
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Web',
  browserRequirements: 'Requires JavaScript',
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: 'Eduardo Álvarez Castañeda',
    url: SITE_URL,
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '9',
      priceCurrency: 'USD',
      billingIncrement: 'P1M',
    },
    {
      '@type': 'Offer',
      name: 'Teams',
      price: '29',
      priceCurrency: 'USD',
      billingIncrement: 'P1M',
    },
  ],
  featureList: [
    'WCAG AA/AAA contrast ratio checker',
    'AI color correction suggestions',
    'Color palette harmony generator',
    'Daltonism (color blindness) simulation',
    'Image color picker',
    'Shareable check URLs',
    'Bulk CSV contrast checker',
    'AI palette generator',
    'Check history',
    'Team collaboration',
  ],
});
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta http-equiv="x-ua-compatible" content="ie=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<link rel="canonical" href={canonical} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Primary meta -->
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Eduardo Álvarez Castañeda" />
		<meta name="application-name" content="C3 Color Contrast Checker" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="C3 Color Contrast Checker" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="C3 — Color Contrast Checker interface showing WCAG compliance results, AI suggestions, and palette tools" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonical} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content="C3 — Color Contrast Checker" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- JSON-LD structured data -->
		<script type="application/ld+json" set:html={jsonLd} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<style>
			:root {
				--font-sans: 'DM Sans', system-ui, sans-serif;
				--font-mono: 'DM Mono', 'Fira Code', monospace;
				--bg: #F3F4F6;
				--surface: #FFFFFF;
				--border: #E5E7EB;
				--border-strong: #D1D5DB;
				--text-primary: #111827;
				--text-secondary: #374151;
				--text-tertiary: #6B7280;
				--text-muted: #9CA3AF;
			}
			* { box-sizing: border-box; }
			body {
				font-family: var(--font-sans);
				background: var(--bg);
				color: var(--text-primary);
				margin: 0;
				min-height: 100vh;
			}
		</style>
	</head>

	<body>
		<div class="min-h-screen flex flex-col">
			<Header />
			<main class="flex-1">
				<div class="max-w-7xl w-full mx-auto px-5 md:px-8 pt-8 pb-20 flex flex-col gap-5">
					<slot />
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
