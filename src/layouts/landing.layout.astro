---
import Header from './components/header.astro';
import Footer from './components/footer.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta http-equiv="x-ua-compatible" content="ie=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<link rel="canonical" href="https://c3.eduardoalvarez.dev" />
		<meta name="title" content="C3 — Color Contrast Checker" />
		<meta name="description" content="Check the contrast ratio between text and background colors and verify WCAG AA/AAA accessibility compliance." />
		<meta name="author" content="Eduardo Álvarez Castañeda" />
		<meta name="application-name" content="C3 Color Contrast Checker" />

		<meta property="og:url" content="https://c3.eduardoalvarez.dev" />
		<meta property="og:title" content="C3 — Color Contrast Checker" />
		<meta property="og:description" content="Check the contrast ratio between text and background colors and verify WCAG AA/AAA accessibility compliance." />
		<meta property="og:image" content="/images/color-contrast-checker.webp" />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://c3.eduardoalvarez.dev" />
		<meta property="twitter:title" content="C3 — Color Contrast Checker" />
		<meta property="twitter:description" content="Check the contrast ratio between text and background colors and verify WCAG AA/AAA accessibility compliance." />
		<meta property="twitter:image" content="/images/color-contrast-checker.webp" />

		<meta name="generator" content={Astro.generator} />
		<title>C3 — Color Contrast Checker</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<style>
			:root {
				--font-sans: 'DM Sans', system-ui, sans-serif;
				--font-mono: 'DM Mono', 'Fira Code', monospace;
				--bg: #F3F4F6;
				--surface: #FFFFFF;
				--border: #E5E7EB;
				--border-strong: #D1D5DB;
				--text-primary: #111827;
				--text-secondary: #374151;
				--text-tertiary: #6B7280;
				--text-muted: #9CA3AF;
			}
			* { box-sizing: border-box; }
			body {
				font-family: var(--font-sans);
				background: var(--bg);
				color: var(--text-primary);
				margin: 0;
				min-height: 100vh;
			}
		</style>
	</head>

	<body>
		<div class="min-h-screen flex flex-col">
			<Header />
			<main class="flex-1">
				<div class="max-w-5xl w-full mx-auto px-5 md:px-8 pt-8 pb-20 flex flex-col gap-5">
					<slot />
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
